input {
  # Receives JSON lines from Fluent Bit running on the DOKS nodes
  tcp {
    port  => 5000
    codec => json_lines
  }
}

filter {
  # Add the log timestamp as @timestamp if present
  if [time] {
    date {
      match   => ["time", "ISO8601"]
      target  => "@timestamp"
      remove_field => ["time"]
    }
  }

  # Tag kubernetes logs for easier filtering in Kibana
  if [kubernetes] {
    mutate {
      add_tag => ["kubernetes"]
    }
  }
}

output {
  elasticsearch {
    hosts    => ["http://elasticsearch:9200"]
    index    => "k8s-logs-%{+YYYY.MM.dd}"
  }
}
