# Copy this file: cp .env.example .env
# Never commit .env — it is gitignored

# ─── Hetzner Cloud ────────────────────────────────────────────────────────────
HCLOUD_TOKEN=your-hetzner-api-token
YOUR_SSH_IP=1.2.3.4

# ─── GitHub Container Registry ────────────────────────────────────────────────
GITHUB_USER=your-github-username
GITHUB_TOKEN=ghp_your-personal-access-token

# ─── Domain & SSL ─────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=your@email.com

# ─── App Secrets ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=strong-random-password-here
DJANGO_SECRET_KEY=50-chars-random-string-for-django-here

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=strong-grafana-admin-password
KIBANA_PASSWORD=strong-kibana-password

# ─── Alerts (optional) ────────────────────────────────────────────────────────
# Leave both empty to disable Telegram notifications (AlertManager stays on null receiver).
# To enable: create a bot via @BotFather, get your chat_id from @userinfobot.
ALERTMANAGER_TELEGRAM_TOKEN=
ALERTMANAGER_TELEGRAM_CHAT_ID=
