# Root .env for the Makefile (DigitalOcean prod targets). Copy: cp .env.example .env
# Never commit .env — it is gitignored.
#
# NOTE: the local app (`make dev`) reads its own secrets from backend/.env
# (ANTHROPIC_API_KEY, VOYAGE_API_KEY, APIFY_TOKEN, …) — not this file.
# DigitalOcean Terraform reads infrastructure/digitalocean/terraform.tfvars
# (do_token, ssh_public_key, admin_ip) — also not this file.

# ─── GitHub Container Registry (make do-images) ───────────────────────────────
GITHUB_USER=your-github-username
GITHUB_TOKEN=ghp_your-personal-access-token   # PAT with packages:write

# ─── DigitalOcean prod ────────────────────────────────────────────────────────
WARSAW_DOMAIN=warsaw.example.com   # app + grafana.<domain>, used by ingress/TLS
ACME_EMAIL=your@email.com          # Let's Encrypt notifications (cert-manager)
GRAFANA_PASSWORD=strong-grafana-admin-password
KIBANA_PASSWORD=strong-kibana-password

# Optional: image tag for do-images / do-deploy (defaults to "latest").
# IMAGE_TAG=latest
