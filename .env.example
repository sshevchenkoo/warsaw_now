# Root .env for the Makefile (DigitalOcean prod targets). Copy: cp .env.example .env
# Never commit .env — it is gitignored.
#
# IMPORTANT: keep comments on their OWN lines. This file is `-include`d as a
# Makefile, so a trailing `# comment` after a value leaves trailing spaces in
# the value (corrupts tokens, CIDRs, etc.).
#
# The local app (`make dev`) reads its own secrets from backend/.env
# (ANTHROPIC_API_KEY, VOYAGE_API_KEY, APIFY_TOKEN, …) — not this file.

# ─── DigitalOcean Terraform (do-infra-*) ──────────────────────────────────────
# DigitalOcean API token, read & write (the provider reads DIGITALOCEAN_TOKEN).
DIGITALOCEAN_TOKEN=dop_v1_your-do-api-token
# Public key for the ELK droplet — e.g. `cat .ssh/id_ed25519.pub`.
TF_VAR_ssh_public_key=ssh-ed25519 AAAA... you@host
# Your public IP in CIDR for SSH + Kibana (curl ifconfig.me, then add /32).
TF_VAR_admin_ip=1.2.3.4/32

# ─── GitHub Container Registry (make do-images) ───────────────────────────────
GITHUB_USER=your-github-username
# PAT with packages:write
GITHUB_TOKEN=ghp_your-personal-access-token

# ─── DigitalOcean app / platform ──────────────────────────────────────────────
# App domain; also serves grafana.<domain>. Used by ingress/TLS.
WARSAW_DOMAIN=warsaw.example.com
# Let's Encrypt notifications (cert-manager).
ACME_EMAIL=your@email.com
GRAFANA_PASSWORD=strong-grafana-admin-password
KIBANA_PASSWORD=strong-kibana-password

# Optional: image tag for do-images / do-deploy (defaults to "latest").
# IMAGE_TAG=latest
