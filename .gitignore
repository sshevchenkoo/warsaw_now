# Secrets — never commit
.env
.ssh/
.kube/
# filled-in k8s Secret (keep only secret.example.yml)
**/k8s/secret.yml

# Terraform
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.backup
.terraform/
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it pins provider
# versions/hashes and must be committed for reproducible `terraform init`.

# Python
__pycache__/
*.pyc
*.pyo
*.py[cod]
venv/
.venv/
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# macOS iCloud / Finder conflict copies ("file 2.ext", "Dockerfile 3", …).
# This repo currently lives on an iCloud-synced folder; ignore the duplicates
# it creates so they never pollute git status or get committed.
* [2-9].*
* [2-9]
*.icloud

# IDE
.idea/
.vscode/

# Obsidian notes (local only — may be a directory or a symlink)
notes
notes/
